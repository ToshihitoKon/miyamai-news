<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= h(og_title) %></title>
  <link rel="alternate" type="application/atom+xml" title="<%= h(og_title) %>" href="<%= h(feed_url) %>">

  <link rel="manifest" href="<%= h(manifest_url) %>">
  <meta name="theme-color" content="#8DA7C2">
  <link rel="apple-touch-icon" href="<%= h(icon_url) %>">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="宮舞ニュース">

  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= h(og_title) %>">
  <meta property="og:description" content="<%= h(description) %>">
  <meta property="og:url" content="<%= h(page_url) %>">
  <meta property="og:image" content="<%= h(cover_url) %>">
  <meta property="og:audio" content="<%= h(current_url) %>">
  <meta property="og:audio:type" content="audio/mpeg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= h(og_title) %>">
  <meta name="twitter:description" content="<%= h(description) %>">
  <meta name="twitter:image" content="<%= h(cover_url) %>">

  <style>
    :root {
      color-scheme: light;
      --moca: #8DA7C2;
      --moca-deep: #5f7d9e;
    }
    body {
      margin: 0;
      font-family: -apple-system, "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      background: var(--moca);
      color: #2b3440;
    }
    .content {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      box-sizing: border-box;
      padding: 32px 0;
    }
    .card {
      width: min(520px, 92vw);
      padding: 28px;
      border-radius: 14px;
      background: #ffffff;
      box-shadow: 0 8px 32px rgba(95, 125, 158, .25);
    }
    .art {
      display: block;
      width: 100%;
      height: auto;
      margin: 0 auto 16px;
      border-radius: 12px;
      border: 3px solid var(--moca);
      cursor: pointer;
    }
    h1 { font-size: 15px; font-weight: 600; margin: 0 0 4px; letter-spacing: .02em; text-align: center; color: var(--moca-deep); }
    .sub { font-size: 12px; color: #7a8896; margin: 0 0 20px; text-align: center; }
    select {
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 16px;
      border-radius: 8px;
      border: 1px solid var(--moca);
      background: #f5f8fb;
      color: #2b3440;
      font-size: 13px;
    }
    audio { width: 100%; }
    .playmode {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 10px;
      padding: 7px 14px;
      border-radius: 8px;
      border: 1px solid var(--moca);
      background: #f5f8fb;
      color: var(--moca-deep);
      font-family: inherit;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
    }
    .playmode:hover { background: #eaf1f8; }
    .news {
      margin-top: 20px;
      border-top: 1px solid #e2e8f0;
      padding-top: 16px;
    }
    .news h2 { font-size: 12px; font-weight: 600; margin: 0 0 10px; color: var(--moca-deep); }
    .news pre {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: inherit;
      font-size: 12px;
      line-height: 1.6;
      color: #3a4652;
    }
    .news a { color: var(--moca-deep); }
    .transcript {
      margin-top: 20px;
      border-top: 1px solid #e2e8f0;
      padding-top: 16px;
    }
    .transcript summary {
      font-size: 12px;
      font-weight: 600;
      color: var(--moca-deep);
      cursor: pointer;
    }
    .transcript pre {
      margin: 10px 0 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: inherit;
      font-size: 12px;
      line-height: 1.6;
      color: #3a4652;
    }
    .site-footer {
      width: 100%;
      box-sizing: border-box;
      padding: 14px 20px;
      background: rgba(255, 255, 255, .82);
      backdrop-filter: blur(6px);
      text-align: center;
    }
    .site-footer .subscribe {
      margin: 0 0 8px;
      font-size: 12px;
    }
    .site-footer .credits {
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 4px 20px;
      font-size: 11px;
      line-height: 1.7;
      color: #5f6b78;
    }
    .site-footer .credits p { margin: 0; }
    .site-footer a { color: var(--moca-deep); }
  </style>
</head>
<body>
  <main class="content">
    <div class="card">
      <img class="art" id="artwork" src="<%= h(cover_url) %>" alt="宮舞モカ">
      <h1><%= h(og_title) %></h1>
      <p class="sub" id="nowplaying"><%= h(date_with_slot(current[0], current[1])) %></p>
      <select id="archive" aria-label="アーカイブ選択">
        <%= options %>
      </select>
      <audio id="player" controls src="<%= h(current_url) %>"></audio>
      <button type="button" id="playmode" class="playmode" aria-label="再生モード切り替え"></button>
      <div class="news">
        <h2>この回で紹介したニュース</h2>
        <pre id="newslist">読み込み中…</pre>
      </div>
      <details class="transcript" id="transcript">
        <summary>文字起こしを読む</summary>
        <pre id="transcripttext">読み込み中…</pre>
      </details>
    </div>
  </main>

  <footer class="site-footer">
    <p class="subscribe"><a href="<%= h(feed_url) %>">フィード（Atom）で購読</a></p>
    <div class="credits">
      <p>音声：VOICEPEAK 宮舞モカ（© 株式会社AHS）<a href="https://www.ah-soft.com/voice/moca/eula.html" target="_blank" rel="noopener">使用許諾</a></p>
      <p>立ち絵：からい 様（<a href="https://seiga.nicovideo.jp/seiga/im11390154" target="_blank" rel="noopener">宮舞モカ立ち絵素材</a>）</p>
      <p>BGM：猫きまぐれBGM工房 様「古びた魔法書」（<a href="https://kim4gure.com/" target="_blank" rel="noopener">猫きまぐれBGM工房</a>）</p>
    </div>
  </footer>

  <script>
    const sel = document.getElementById('archive');
    const player = document.getElementById('player');
    const now = document.getElementById('nowplaying');
    const newslist = document.getElementById('newslist');
    const artwork = document.getElementById('artwork');
    const transcript = document.getElementById('transcript');
    const transcripttext = document.getElementById('transcripttext');
    const playmode = document.getElementById('playmode');

    const escapeHtml = (s) => s
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');

    const linkify = (text) =>
      escapeHtml(text).replace(/https?:\/\/[^\s<]+/g,
        (url) => `<a href="${url}" target="_blank" rel="noopener">${url}</a>`);

    const relativeLabel = (iso) => {
      if (!iso) return '';
      const diffHour = Math.floor((Date.now() - new Date(iso).getTime()) / 3600000);
      if (diffHour < 1) return 'ついさっき';
      if (diffHour < 24) return `${diffHour}時間前`;
      return `${Math.floor(diffHour / 24)}日前`;
    };

    // select の各 option の見た目テキストに「・N時間前」を付け直す。
    // data-label(元のラベル)を基準に毎回組み立て直すので、繰り返し呼んでも
    // 「・3時間前・3時間前」のように積み上がらない(冪等)。
    const applyRelativeLabels = () => {
      Array.from(sel.options).forEach((opt) => {
        const ago = relativeLabel(opt.dataset.updatedAt);
        opt.textContent = ago ? `${opt.dataset.label}・${ago}` : opt.dataset.label;
      });
      now.textContent = sel.options[sel.selectedIndex].textContent;
    };

    const usedUrlFor = (mp3Url) => mp3Url.replace(/\.mp3$/, '.used.txt');

    const loadNews = async (mp3Url) => {
      newslist.textContent = '読み込み中…';
      try {
        const res = await fetch(usedUrlFor(mp3Url), { cache: 'no-cache' });
        if (!res.ok) throw new Error(res.status);
        newslist.innerHTML = linkify(await res.text());
      } catch (e) {
        newslist.textContent = 'ニュース一覧はありません';
      }
    };

    const transcriptUrlFor = (mp3Url) => mp3Url.replace(/\.mp3$/, '.transcript.txt');

    const loadTranscript = async (mp3Url) => {
      transcripttext.textContent = '読み込み中…';
      try {
        const res = await fetch(transcriptUrlFor(mp3Url), { cache: 'no-cache' });
        if (!res.ok) throw new Error(res.status);
        transcripttext.textContent = await res.text();
      } catch (e) {
        transcripttext.textContent = '文字起こしはありません';
      }
    };

    transcript.addEventListener('toggle', () => {
      if (transcript.open && transcript.dataset.loadedFor !== player.src) {
        transcript.dataset.loadedFor = player.src;
        loadTranscript(player.src);
      }
    });

    // select の指定 index の回に切り替え、プレーヤーと付随表示を更新する。
    // select 操作(change)と連続再生の自動遷移で共通に使う。
    const switchToArchive = (index) => {
      sel.selectedIndex = index;
      player.src = sel.value;
      now.textContent = sel.options[index].textContent;
      loadNews(sel.value);
      if (transcript.open) {
        transcript.dataset.loadedFor = player.src;
        loadTranscript(player.src);
      } else {
        delete transcript.dataset.loadedFor;
      }
    };

    sel.addEventListener('change', () => switchToArchive(sel.selectedIndex));

    // 再生モード。ボタンを押すたびに一曲→連続→リピートの順で循環する。
    // - single  : 1曲終わったら停止(既定)
    // - sequential: 1曲終わったら1つ古い回(select上で次の index)へ進む。
    //              最古(末尾)まで到達したら停止する。
    // - repeat   : 同じ回を繰り返す(単曲リピート)。
    const MODES = [
      { key: 'single', icon: '▶️', label: '一曲' },
      { key: 'sequential', icon: '⏭️', label: '連続' },
      { key: 'repeat', icon: '🔂', label: 'リピート' },
    ];
    let modeIndex = 0;

    const applyPlaymode = () => {
      const mode = MODES[modeIndex];
      player.loop = mode.key === 'repeat';
      playmode.textContent = `${mode.icon} ${mode.label}`;
    };

    playmode.addEventListener('click', () => {
      modeIndex = (modeIndex + 1) % MODES.length;
      applyPlaymode();
    });

    // 曲終端。連続再生時のみ1つ古い回へ自動で進める。
    // repeat は audio.loop に任せるため ended が発火せず、ここには来ない。
    player.addEventListener('ended', () => {
      if (MODES[modeIndex].key !== 'sequential') return;
      const next = sel.selectedIndex + 1; // select は最新が先頭・降順なので +1 が1つ古い回
      if (next >= sel.options.length) return; // 最古まで到達したら停止
      switchToArchive(next);
      player.play();
    });

    applyPlaymode();

    const togglePlay = () => {
      if (player.paused) {
        player.play();
      } else {
        player.pause();
      }
    };

    artwork.addEventListener('click', togglePlay);

    document.addEventListener('keydown', (e) => {
      if (e.code !== 'Space') return;
      const active = document.activeElement;
      if (active === sel || active === player) return;
      const tag = active && active.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON') return;
      e.preventDefault();
      togglePlay();
    });

    loadNews(player.src);
    applyRelativeLabels();
    setInterval(applyRelativeLabels, 60000);
  </script>
</body>
</html>
