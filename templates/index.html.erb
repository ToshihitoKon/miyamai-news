<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= h(og_title) %></title>
  <link rel="alternate" type="application/atom+xml" title="<%= h(og_title) %>" href="<%= h(feed_url) %>">

  <link rel="manifest" href="<%= h(manifest_url) %>">
  <meta name="theme-color" content="#8DA7C2">
  <link rel="apple-touch-icon" href="<%= h(icon_url) %>">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="宮舞ニュース">

  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= h(og_title) %>">
  <meta property="og:description" content="<%= h(description) %>">
  <meta property="og:url" content="<%= h(page_url) %>">
  <meta property="og:image" content="<%= h(cover_url) %>">
  <meta property="og:audio" content="<%= h(current_url) %>">
  <meta property="og:audio:type" content="audio/mpeg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= h(og_title) %>">
  <meta name="twitter:description" content="<%= h(description) %>">
  <meta name="twitter:image" content="<%= h(cover_url) %>">

  <style>
    :root {
      color-scheme: light;
      --moca: #8DA7C2;
      --moca-deep: #5f7d9e;
    }
    body {
      margin: 0;
      font-family: -apple-system, "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      background: var(--moca);
      color: #2b3440;
    }
    .content {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      box-sizing: border-box;
      padding: 32px 0;
    }
    .card {
      width: min(800px, 92vw);
      padding: 28px;
      border-radius: 14px;
      background: #ffffff;
      box-shadow: 0 8px 32px rgba(95, 125, 158, .25);
    }
    /* カバー画像〜プレーヤーだけをカード内で中央寄せの狭い幅に保つ。
       ニュース一覧・文字起こしはこの外側に置き、カードの全幅を使わせる。 */
    .player-wrap {
      max-width: 520px;
      margin: 0 auto;
    }
    .art {
      display: block;
      width: 100%;
      height: auto;
      margin: 0 auto 16px;
      border-radius: 12px;
      border: 3px solid var(--moca);
      cursor: pointer;
    }
    h1 { font-size: 15px; font-weight: 600; margin: 0 0 4px; letter-spacing: .02em; text-align: center; color: var(--moca-deep); }
    .sub { font-size: 12px; color: #7a8896; margin: 0 0 20px; text-align: center; }
    select {
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 16px;
      border-radius: 8px;
      border: 1px solid var(--moca);
      background: #f5f8fb;
      color: #2b3440;
      font-size: 13px;
    }
    /* controls を外した audio は音源エンジンとしてのみ残す（不可視） */
    audio { display: none; }

    /* カスタムプレーヤー: 上段シークバー / 下段コントロールの2段構成 */
    /* padding 込みで幅を収めるためプレーヤー配下だけ border-box にする
       (グローバルには適用せず既存レイアウトへの影響を避ける) */
    .player, .player * { box-sizing: border-box; }
    .player {
      display: flex;
      flex-direction: column;
      gap: 6px;
      width: 100%;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid var(--moca);
      background: #f5f8fb;
    }
    /* シークバー行。下側にだけ少し余白を足す(上は .player の gap があるため詰める) */
    .player .rowtop { padding: 0 2px 6px; }
    .player .rowbot { display: flex; align-items: center; gap: 10px; }
    .pbtn {
      flex: none;
      width: 34px;
      height: 34px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: none;
      border-radius: 11px;
      background: var(--moca);
      color: #fff;
      cursor: pointer;
      padding: 0;
    }
    .pbtn svg { width: 16px; height: 16px; display: block; }
    .pbtn.ghost { background: transparent; color: var(--moca-deep); width: 30px; height: 30px; }
    .pbtn.ghost:hover { background: #e6eef6; }
    .time {
      flex: none;
      font-size: 11px;
      color: #7a8896;
      font-variant-numeric: tabular-nums;
    }
    .spacer { flex: 1; }
    input[type=range].seek {
      width: 100%;
      -webkit-appearance: none;
      appearance: none;
      height: 4px;
      border-radius: 2px;
      /* 再生済み部分を --pct まで塗る。残りは #d6e0eb の背景色 */
      background: linear-gradient(var(--moca), var(--moca)) no-repeat;
      background-size: var(--pct, 0%) 100%;
      background-color: #d6e0eb;
      cursor: pointer;
      margin: 0;
    }
    input[type=range].seek::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: var(--moca-deep);
      border: 2px solid #fff;
      box-shadow: 0 1px 3px rgba(95, 125, 158, .5);
    }
    input[type=range].seek::-moz-range-thumb {
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: var(--moca-deep);
      border: 2px solid #fff;
    }
    /* モードトグル: テキストラベル。将来 Font Awesome 等へ差し替えやすいよう最小限 */
    .modebtn {
      flex: none;
      border: 1px solid var(--moca);
      border-radius: 10px;
      background: #fff;
      color: var(--moca-deep);
      font-size: 11px;
      font-weight: 600;
      font-family: inherit;
      padding: 5px 10px;
      cursor: pointer;
      min-width: 62px;
      text-align: center;
    }
    .modebtn:hover { background: #eaf1f8; }
    .news {
      margin-top: 20px;
      border-top: 1px solid #e2e8f0;
      padding-top: 16px;
    }
    .news h2 { font-size: 12px; font-weight: 600; margin: 0 0 10px; color: var(--moca-deep); }
    /* 生テキスト用フォールバック（パース失敗時・旧フォーマット回）。 */
    .news pre {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: inherit;
      font-size: 12px;
      line-height: 1.6;
      color: #3a4652;
    }
    /* 構造化表示（.used.html の innerHTML をそのまま差し込む。Ruby 側
       UsedNewsMarkdown.render の出力）。カテゴリ・タイトルは見出しタグを使わず
       div + スタイルで表現し、ページ全体の見出しアウトラインに混ぜない。 */
    .news-cat {
      font-size: 12px;
      font-weight: 700;
      color: var(--moca-deep);
      margin: 14px 0 6px;
      padding-bottom: 4px;
      border-bottom: 1px solid #e2e8f0;
    }
    /* 先頭カテゴリの上マージンは詰める（newslist 直下の最初の要素が .news-cat）。 */
    #newslist > .news-cat:first-child { margin-top: 0; }
    .news-item { margin: 0 0 12px; }
    .news-title { font-size: 12px; font-weight: 600; line-height: 1.5; }
    .news-title a { color: var(--moca-deep); }
    .news-sum {
      margin: 2px 0 0;
      font-size: 12px;
      line-height: 1.6;
      color: #3a4652;
    }
    .news-meta { margin-top: 2px; font-size: 11px; color: #8a94a0; }
    .news a { color: var(--moca-deep); }
    .transcript {
      margin-top: 20px;
      border-top: 1px solid #e2e8f0;
      padding-top: 16px;
    }
    .transcript summary {
      font-size: 12px;
      font-weight: 600;
      color: var(--moca-deep);
      cursor: pointer;
    }
    .transcript pre {
      margin: 10px 0 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: inherit;
      font-size: 12px;
      line-height: 1.6;
      color: #3a4652;
    }
    .site-footer {
      width: 100%;
      box-sizing: border-box;
      padding: 14px 20px;
      background: rgba(255, 255, 255, .82);
      backdrop-filter: blur(6px);
      text-align: center;
    }
    .site-footer .subscribe {
      margin: 0 0 8px;
      font-size: 12px;
    }
    .site-footer .credits {
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 4px 20px;
      font-size: 11px;
      line-height: 1.7;
      color: #5f6b78;
    }
    .site-footer .credits p { margin: 0; }
    .site-footer a { color: var(--moca-deep); }
  </style>
</head>
<body>
  <main class="content">
    <div class="card">
      <div class="player-wrap">
        <img class="art" id="artwork" src="<%= h(cover_url) %>" alt="宮舞モカ">
        <h1><%= h(og_title) %></h1>
        <p class="sub" id="nowplaying"><%= h(date_with_slot(current[0], current[1])) %></p>
        <select id="archive" aria-label="アーカイブ選択">
          <%= options %>
        </select>
        <audio id="player" preload="metadata" src="<%= h(current_url) %>"></audio>
        <div class="player">
          <div class="rowtop">
            <input type="range" class="seek" id="seek" min="0" max="100" value="0" step="any" aria-label="シーク位置">
          </div>
          <div class="rowbot">
            <button type="button" class="pbtn play" id="playpause" aria-label="再生／一時停止"></button>
            <span class="time" id="time">0:00 / 0:00</span>
            <span class="spacer"></span>
            <button type="button" class="pbtn ghost" id="mute" aria-label="ミュート"></button>
            <button type="button" class="modebtn" id="playmode" aria-label="再生モード切り替え"></button>
          </div>
        </div>
      </div>
      <div class="news">
        <h2>この回で紹介したニュース</h2>
        <div id="newslist"><pre>読み込み中…</pre></div>
      </div>
      <details class="transcript" id="transcript">
        <summary>文字起こしを読む</summary>
        <pre id="transcripttext">読み込み中…</pre>
      </details>
    </div>
  </main>

  <footer class="site-footer">
    <p class="subscribe"><a href="<%= h(feed_url) %>">フィード（Atom）で購読</a></p>
    <div class="credits">
      <p>音声：VOICEPEAK 宮舞モカ（© 株式会社AHS）<a href="https://www.ah-soft.com/voice/moca/eula.html" target="_blank" rel="noopener">使用許諾</a></p>
      <p>立ち絵：からい 様（<a href="https://seiga.nicovideo.jp/seiga/im11390154" target="_blank" rel="noopener">宮舞モカ立ち絵素材</a>）</p>
      <p>BGM：猫きまぐれBGM工房 様「古びた魔法書」（<a href="https://kim4gure.com/" target="_blank" rel="noopener">猫きまぐれBGM工房</a>）</p>
    </div>
  </footer>

  <script>
    const sel = document.getElementById('archive');
    const player = document.getElementById('player');
    const now = document.getElementById('nowplaying');
    const newslist = document.getElementById('newslist');
    const artwork = document.getElementById('artwork');
    const transcript = document.getElementById('transcript');
    const transcripttext = document.getElementById('transcripttext');
    const playmode = document.getElementById('playmode');
    const seek = document.getElementById('seek');
    const timeLabel = document.getElementById('time');
    const playpause = document.getElementById('playpause');
    const mute = document.getElementById('mute');

    // カスタムプレーヤーの再生/一時停止・音量アイコン(ネイティブ controls を廃したため自前描画)
    const ICON = {
      play: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>',
      pause: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>',
      volume: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 10v4h4l5 5V5L7 10H3zm13 2a4 4 0 00-2-3.46v6.92A4 4 0 0016 12z"/></svg>',
      muted: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 10v4h4l5 5V5L7 10H3zm18.3-.7l-1.4-1.4L17 10.8 14.2 8l-1.4 1.4L15.6 12l-2.8 2.8 1.4 1.4L17 13.4l2.9 2.9 1.4-1.4L18.4 12z"/></svg>',
    };

    const fmtTime = (sec) => {
      if (!isFinite(sec)) sec = 0;
      const m = Math.floor(sec / 60);
      const s = Math.floor(sec % 60);
      return `${m}:${String(s).padStart(2, '0')}`;
    };

    const escapeHtml = (s) => s
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');

    const linkify = (text) =>
      escapeHtml(text).replace(/https?:\/\/[^\s<]+/g,
        (url) => `<a href="${url}" target="_blank" rel="noopener">${url}</a>`);

    const relativeLabel = (iso) => {
      if (!iso) return '';
      const diffHour = Math.floor((Date.now() - new Date(iso).getTime()) / 3600000);
      if (diffHour < 1) return 'ついさっき';
      if (diffHour < 24) return `${diffHour}時間前`;
      return `${Math.floor(diffHour / 24)}日前`;
    };

    // select の各 option の見た目テキストに「・N時間前」を付け直す。
    // data-label(元のラベル)を基準に毎回組み立て直すので、繰り返し呼んでも
    // 「・3時間前・3時間前」のように積み上がらない(冪等)。
    const applyRelativeLabels = () => {
      Array.from(sel.options).forEach((opt) => {
        const ago = relativeLabel(opt.dataset.updatedAt);
        opt.textContent = ago ? `${opt.dataset.label}・${ago}` : opt.dataset.label;
      });
      now.textContent = sel.options[sel.selectedIndex].textContent;
    };

    const usedHtmlUrlFor = (mp3Url) => mp3Url.replace(/\.mp3$/, '.used.html');
    const usedTextUrlFor = (mp3Url) => mp3Url.replace(/\.mp3$/, '.used.txt');

    // 生テキストを <pre> で表示する（読み込み中・エラー・.used.html 未生成の回の
    // フォールバック用）。linkify を通すと URL だけリンク化される。
    const showNewsRaw = (text, { link = false } = {}) => {
      const pre = document.createElement('pre');
      if (link) pre.innerHTML = linkify(text); else pre.textContent = text;
      newslist.replaceChildren(pre);
    };

    // .used.html（Ruby 側 UsedNewsMarkdown.render が publish 時に事前生成した構造化
    // HTML）を優先して fetch し、成功すればそのまま innerHTML に差し込む。404・fetch
    // 失敗（旧フォーマットの回・パース不能だった回は .used.html 自体が存在しない）は
    // .used.txt を fetch して生テキスト表示(<pre>+linkify)へフォールバックする。
    const loadNews = async (mp3Url) => {
      showNewsRaw('読み込み中…');
      try {
        const htmlRes = await fetch(usedHtmlUrlFor(mp3Url), { cache: 'no-cache' });
        if (htmlRes.ok) {
          newslist.innerHTML = await htmlRes.text();
          return;
        }
      } catch (e) {
        // .used.html の fetch 自体が失敗した場合も .used.txt へフォールバックする。
      }

      try {
        const res = await fetch(usedTextUrlFor(mp3Url), { cache: 'no-cache' });
        if (!res.ok) throw new Error(res.status);
        showNewsRaw(await res.text(), { link: true });
      } catch (e) {
        showNewsRaw('ニュース一覧はありません');
      }
    };

    const transcriptUrlFor = (mp3Url) => mp3Url.replace(/\.mp3$/, '.transcript.txt');

    const loadTranscript = async (mp3Url) => {
      transcripttext.textContent = '読み込み中…';
      try {
        const res = await fetch(transcriptUrlFor(mp3Url), { cache: 'no-cache' });
        if (!res.ok) throw new Error(res.status);
        transcripttext.textContent = await res.text();
      } catch (e) {
        transcripttext.textContent = '文字起こしはありません';
      }
    };

    transcript.addEventListener('toggle', () => {
      if (transcript.open && transcript.dataset.loadedFor !== player.src) {
        transcript.dataset.loadedFor = player.src;
        loadTranscript(player.src);
      }
    });

    // select の指定 index の回に切り替え、プレーヤーと付随表示を更新する。
    // select 操作(change)と連続再生の自動遷移で共通に使う。
    const switchToArchive = (index) => {
      sel.selectedIndex = index;
      player.src = sel.value;
      now.textContent = sel.options[index].textContent;
      // src 差し替えで duration が変わる。実値は loadedmetadata で確定するので暫定リセット
      seek.value = 0;
      seek.style.setProperty('--pct', '0%');
      timeLabel.textContent = '0:00 / 0:00';
      loadNews(sel.value);
      if (transcript.open) {
        transcript.dataset.loadedFor = player.src;
        loadTranscript(player.src);
      } else {
        delete transcript.dataset.loadedFor;
      }
    };

    sel.addEventListener('change', () => switchToArchive(sel.selectedIndex));

    // 再生モード。ボタンを押すたびに一曲→連続→リピートの順で循環する。
    // - single  : 1曲終わったら停止(既定)
    // - sequential: 1曲終わったら1つ古い回(select上で次の index)へ進む。
    //              最古(末尾)まで到達したら停止する。
    // - repeat   : 同じ回を繰り返す(単曲リピート)。
    // ラベルはここに集約。将来アイコン化する場合もこの配列を変えればよい。
    const MODES = [
      { key: 'single', label: '一曲' },
      { key: 'sequential', label: '連続' },
      { key: 'repeat', label: 'リピート' },
    ];
    let modeIndex = 0;

    const applyPlaymode = () => {
      const mode = MODES[modeIndex];
      player.loop = mode.key === 'repeat';
      playmode.textContent = mode.label;
    };

    // ネイティブ controls を廃したので、再生状態・シーク・音量表示を自前で描画する。
    const renderPlay = () => { playpause.innerHTML = player.paused ? ICON.play : ICON.pause; };

    const renderMute = () => {
      mute.innerHTML = player.muted ? ICON.muted : ICON.volume;
      mute.setAttribute('aria-label', player.muted ? 'ミュート解除' : 'ミュート');
    };

    const renderTime = () => {
      const pct = player.duration ? (player.currentTime / player.duration) * 100 : 0;
      seek.value = pct;
      seek.style.setProperty('--pct', pct + '%');
      timeLabel.textContent = `${fmtTime(player.currentTime)} / ${fmtTime(player.duration)}`;
    };

    playmode.addEventListener('click', () => {
      modeIndex = (modeIndex + 1) % MODES.length;
      applyPlaymode();
    });

    // 曲終端。連続再生時のみ1つ古い回へ自動で進める。
    // repeat は audio.loop に任せるため ended が発火せず、ここには来ない。
    player.addEventListener('ended', () => {
      if (MODES[modeIndex].key !== 'sequential') return;
      const next = sel.selectedIndex + 1; // select は最新が先頭・降順なので +1 が1つ古い回
      if (next >= sel.options.length) return; // 最古まで到達したら停止
      switchToArchive(next);
      // src 差し替え直後の play。メタデータ読み込み後に自動再生される。
      // 自動再生ポリシー等での reject は握り潰す(連続再生はユーザー操作起点なので通常起きない)。
      player.play().catch(() => {});
    });

    applyPlaymode();

    const togglePlay = () => {
      if (player.paused) {
        player.play();
      } else {
        player.pause();
      }
    };

    // 再生トグルは3経路(再生ボタン・アートワーク・Space)が同じ togglePlay を共有し、
    // play/pause イベント経由で renderPlay がアイコンを同期する。
    playpause.addEventListener('click', togglePlay);
    artwork.addEventListener('click', togglePlay);
    player.addEventListener('play', renderPlay);
    player.addEventListener('pause', renderPlay);
    player.addEventListener('timeupdate', renderTime);
    player.addEventListener('loadedmetadata', renderTime); // src 切替後に duration を反映
    player.addEventListener('volumechange', renderMute);

    seek.addEventListener('input', () => {
      if (!isFinite(player.duration)) return; // メタデータ未ロード時のシークは無効
      player.currentTime = (seek.value / 100) * player.duration;
      renderTime();
    });

    mute.addEventListener('click', () => {
      player.muted = !player.muted;
      renderMute();
    });

    document.addEventListener('keydown', (e) => {
      if (e.code !== 'Space') return;
      const active = document.activeElement;
      if (active === sel || active === player) return;
      const tag = active && active.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON') return;
      e.preventDefault();
      togglePlay();
    });

    renderPlay();
    renderMute();
    renderTime();
    loadNews(player.src);
    applyRelativeLabels();
    setInterval(applyRelativeLabels, 60000);
  </script>
</body>
</html>
